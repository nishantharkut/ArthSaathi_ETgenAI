# ArthSaathi Backend — Environment Variables
# Copy to .env and fill in values. App works without any keys (uses rule-engine fallback).

CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# Supabase — same URL as frontend VITE_SUPABASE_URL (required if JWTs use ECC / ES256)
SUPABASE_URL=

# Supabase anon key — same as frontend VITE_SUPABASE_ANON_KEY (used for /auth/v1/user fallback)
SUPABASE_ANON_KEY=

# Legacy HS256 JWT — Dashboard → API → JWT signing shared secret (not the anon key)
SUPABASE_JWT_SECRET=

# LLM API Keys (optional — set at least one for AI mentor + advisor)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
